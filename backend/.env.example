# Plaid API Credentials
# Get these from the Plaid Dashboard: https://dashboard.plaid.com/team/keys
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_secret_here

# Plaid Environment: 'sandbox', 'development', or 'production'
# Use 'sandbox' for testing with fake data.
PLAID_ENV=sandbox

# Firebase Credentials (not needed if running in Firebase Functions)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json
